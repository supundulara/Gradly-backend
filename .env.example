# MongoDB Atlas URIs — copy this file to .env and fill in your real credentials
USER_DB_URI=mongodb+srv://username:password@cluster0.mongodb.net/decp_users?retryWrites=true&w=majority
POST_DB_URI=mongodb+srv://username:password@cluster0.mongodb.net/decp_posts?retryWrites=true&w=majority
OPPORTUNITY_DB_URI=mongodb+srv://username:password@cluster0.mongodb.net/decp_opportunities?retryWrites=true&w=majority
MESSAGE_DB_URI=mongodb+srv://username:password@cluster0.mongodb.net/decp_messages?retryWrites=true&w=majority
NOTIFICATION_DB_URI=mongodb+srv://username:password@cluster0.mongodb.net/decp_notifications?retryWrites=true&w=majority

# Eureka / Service Discovery
EUREKA_URI=http://service-discovery:8761/eureka

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

